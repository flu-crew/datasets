	set tipLabels.colorAttribute="Names";
	set tipLabels.displayAttribute="vaccine";
	set tipLabels.fontName="Arial Black";
	set tipLabels.fontSize=20;
	set tipLabels.fontStyle=0;
	set tipLabels.isShown=true;
	set tipLabels.significantDigits=4;
	set trees.order=true;
	set trees.orderType="increasing";
	set trees.rooting=true;
	set trees.rootingType="Midpoint";
	set trees.transform=false;
	set trees.transformType="cladogram";
end;

